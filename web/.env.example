# Copy to `.env.local` and fill in the values you need.
# See web/README.md for what each variable does.

# Mapbox — required for the interactive globe on /globe
NEXT_PUBLIC_MAPBOX_TOKEN=

# Clerk — optional; both keys are required to enable sign-in on /my
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/my
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/my
