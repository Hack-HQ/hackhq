# Copy to `.env.local` and fill in the values you need.
# See web/README.md for what each variable does.

# Mapbox — required for the interactive globe on /globe
NEXT_PUBLIC_MAPBOX_TOKEN=

# Clerk — optional; both keys are required to enable sign-in on /my.
# The auth routes and post-sign-in redirect are wired in code (proxy.ts and
# components/hq/auth-screen.tsx), so no NEXT_PUBLIC_CLERK_*_URL vars are needed.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# PostHog — optional; both keys required to enable analytics.
# Get your project token from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Drizzle/Supabase Postgres — only needed when running npm run db:* scripts.
# Use the direct or pooled Postgres connection string from Supabase.
DATABASE_URL=
